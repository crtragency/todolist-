# Copy to .env and fill in.

# --- PostgreSQL (Supabase) ---
# DATABASE_URL: pooled connection used by the app at runtime.
#   Supabase -> Project Settings -> Database -> Connection string -> "Transaction pooler"
#   Append ?pgbouncer=true&connection_limit=1
# Example:
#   postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://user:password@localhost:5432/todolist?schema=public"

# DIRECT_URL: direct (non-pooled) connection used only for migrations.
#   Supabase -> same page -> "Direct connection" (or "Session pooler", port 5432)
# Example:
#   postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://user:password@localhost:5432/todolist?schema=public"

# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"
