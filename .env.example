# Copy to .env and fill in.
# PostgreSQL connection string. On Vercel, use Vercel Postgres / Neon and set POSTGRES_PRISMA_URL.
DATABASE_URL="postgresql://user:password@localhost:5432/todolist?schema=public"

# Secret used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET="change-me-to-a-long-random-string"
